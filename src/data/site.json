          "header": {
            "vn": "Bộ nhận diện thương hiệu cho thương hiệu đồ ăn nhanh [[b:HOTNDOGS]]",
            "en": "Branding Identity for [[b:HOTNDOGS]] - Fast food brand"
          },
          "theme": "red",
          "headerLogo": { "src": "/assets/branding/logo-mark.png", "alt": "HOTNDOGS logo" },
          "headerWordmark": "HOTNDOGS",
          "headerDecorations": [
            { "media": { "src": "/assets/branding/header-icon-1.png", "alt": "" }, "x": 1585, "y": 32, "w": 56, "h": 71 },
