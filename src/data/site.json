            {
              "type": "brand-info",
              "logo": { "src": "/assets/branding/logo-main.png", "alt": "HOTNDOGS main logo" },
              "packaging": { "src": "/assets/branding/packaging.png", "alt": "HOTNDOGS packaging" },
              "fieldLabel": "Lĩnh vực/Field",
              "fieldBody": {
                "vn": "Kinh doanh đồ ăn nhanh: hotdog, soda,...",
                "en": "Fastfood business, specially hotdog, soda,..."
              },
              "meaningLabel": "Ý nghĩa logo/Logo meaning",
              "meaningBody": {
                "vn": "[[r:HOTNDOGS]] là sự kết hợp giữa:\n[[r:HOT]]: nóng, năng lượng, nổi bật, cá tính. [[r:DOGS]]: thân thiện, trung thành, gần gũi. Logo chú chó và chữ [[r:HOTNDOGS]] dạng tròn, mạnh tạo nên cảm giác: “Một chú chó có cá tính mạnh nhưng vẫn rất đáng yêu.”",
                "en": "[[b:HOTNDOGS]] is a combination of: [[b:HOT]]: heat, energy, boldness, and personality. [[b:DOGS]]: friendliness, loyalty, playfulness, and familiarity. [[b:HOTNDOGS]], with its slightly bold, rounded typography, creates the feeling of: “A dog with a strong personality, yet still irresistibly lovable.”"
              },
              "visionLabel": "Tầm nhìn và sứ mệnh/Vision & mission",
              "vision": {
                "vn": "Trở thành một thương hiệu biểu tượng của sự vui vẻ, cá tính và năng lượng tích cực, mang đến những trải nghiệm đáng nhớ và đầy cảm hứng.",
                "en": "To become an iconic brand of fun, personality, and positive energy, creating memorable and inspiring experiences."
              },
              "mission": {
                "vn": "Tạo ra những trải nghiệm vui vẻ, gần gũi và đầy năng lượng, kết nối mọi người thông qua sự hài hước, cá tính và tinh thần “HOT”.",
                "en": "To create playful, relatable, and energetic experiences that bring people together through humor, personality, and a little bit of “HOT” energy."
              },
              "ctaLabel": "Khám phá ngay"
            }
          ]
        },
